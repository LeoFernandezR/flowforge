# Local Postgres (Docker)
DATABASE_URL="postgresql://flowforge:flowforge@localhost:5432/flowforge?schema=public"

# Production (Neon)
# DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/<db>?sslmode=require"

# Gemini (Google GenAI)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-latest"

# Groq
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-20b"

# Max retries when the model returns output that fails Zod validation (default 2 → up to 3
# attempts). Set to 0 to disable retries.
FLOWFORGE_MAX_VALIDATION_RETRIES="2"
